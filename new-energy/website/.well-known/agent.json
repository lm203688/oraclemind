{
  "$schema": "https://agents.well-known.dev/v1",
  "name": "EnergyDB",
  "description": "New energy technology knowledge base - solar, storage, hydrogen, grid tech",
  "url": "https://energy.genetech.tools",
  "category": "新能源",
  "api": {
    "type": "rest",
    "base_url": "https://energy.genetech.tools/api",
    "openapi": "https://energy.genetech.tools/api/openapi.json",
    "endpoints": [
      {
        "path": "/api/solar_tech.json",
        "method": "GET",
        "description": "Get solar tech data",
        "content_type": "application/json"
      },
      {
        "path": "/api/energy_storage.json",
        "method": "GET",
        "description": "Get energy storage data",
        "content_type": "application/json"
      },
      {
        "path": "/api/hydrogen_energy.json",
        "method": "GET",
        "description": "Get hydrogen energy data",
        "content_type": "application/json"
      },
      {
        "path": "/api/grid_tech.json",
        "method": "GET",
        "description": "Get grid tech data",
        "content_type": "application/json"
      },
      {
        "path": "/api/wind_energy.json",
        "method": "GET",
        "description": "Get wind energy data",
        "content_type": "application/json"
      },
      {
        "path": "/api/nuclear_renewable.json",
        "method": "GET",
        "description": "Get nuclear renewable data",
        "content_type": "application/json"
      },
      {
        "path": "/api/data.json",
        "method": "GET",
        "description": "Get complete structured data",
        "content_type": "application/json"
      },
      {
        "path": "/api/entities.json",
        "method": "GET",
        "description": "Get flat entity list",
        "content_type": "application/json"
      },
      {
        "path": "/api/cross-refs.json",
        "method": "GET",
        "description": "Get cross-references to related knowledge bases",
        "content_type": "application/json"
      }
    ]
  },
  "capabilities": [
    "query",
    "browse",
    "cross_reference"
  ],
  "content_types": [
    "application/json",
    "text/html",
    "text/plain"
  ],
  "auth": {
    "type": "none"
  },
