{
  "manifest_version": 3,
  "name": "AIShield - AI工具安全评分",
  "version": "1.0.0",
  "description": "在GPT Store和MCP工具市场自动显示安全评分",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://gpts.store/*",
    "https://smithery.ai/*",
    "https://mcp.so/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/shield16.png",
      "48": "icons/shield48.png",
      "128": "icons/shield128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/g/*",
        "https://gpts.store/*",
        "https://smithery.ai/*",
        "https://mcp.so/*"
      ],
      "js": ["content.js"],
      "css": ["badge.css"]
    }
  ],
  "icons": {
    "16": "icons/shield16.png",
    "48": "icons/shield48.png",
    "128": "icons/shield128.png"
  }
}
