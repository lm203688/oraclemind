{
  "name": "agent-trust-videos",
  "version": "1.0.0",
  "description": "TikTok promo videos for agent-trust-protocol",
  "scripts": {
    "render:demo": "remotion render src/index.tsx AgentTrustDemo out/agent-trust-demo.mp4",
    "render:story": "remotion render src/index.tsx AgentTrustStory out/agent-trust-story.mp4",
