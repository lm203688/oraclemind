/* ============================================
   AgentTrust 微信小程序 - 全局样式
   设计风格：精致/克制（Luxury/Refined）
   配色：深黑底色 + 温暖金色强调
   ============================================ */

/* -- 设计变量 -- */
page {
  --bg-primary: #0a0a0a;
  --bg-secondary: #141414;
  --bg-card: #1a1a1a;
  --text-primary: #fafafa;
  --text-secondary: #a1a1a1;
  --text-tertiary: #666666;
  --accent: #ff6b35;
  --accent-hover: #ff8555;
  --success: #10b981;
  --warning: #f59e0b;
  --danger: #ef4444;
  
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  
  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* -- 通用工具类 -- */
.container {
  padding: var(--spacing-md);
}

.card {
  background-color: var(--bg-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
}

.badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.badge--accent {
  background-color: rgba(255, 107, 53, 0.15);
  color: var(--accent);
}

.badge--success {
  background-color: rgba(16, 185, 129, 0.15);
  color: var(--success);
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: var(--radius-md);
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  transition: all 0.2s ease;
}

.btn--primary {
  background-color: var(--accent);
  color: white;
}

.btn--primary:active {
  background-color: var(--accent-hover);
  transform: scale(0.98);
}

.btn--ghost {
  background-color: transparent;
  color: var(--text-secondary);
  border: 1rpx solid var(--text-tertiary);
}

/* -- 信任分展示组件 -- */
.trust-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.trust-score__value {
  font-size: 96rpx;
  font-weight: 700;
  line-height: 1;
  color: var(--accent);
}

.trust-score__label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: var(--spacing-xs);
}

.trust-score__bar {
  width: 100%;
  height: 8rpx;
  background-color: var(--bg-secondary);
  border-radius: 4rpx;
  margin-top: var(--spacing-sm);
  overflow: hidden;
}

.trust-score__bar-fill {
  height: 100%;
  background-color: var(--accent);
  border-radius: 4rpx;
  transition: width 0.6s ease;
}

/* -- 动画 -- */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in {
  animation: fadeIn 0.4s ease forwards;
}

/* -- 分区标题 -- */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-sm);
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: var(--spacing-md);
}
