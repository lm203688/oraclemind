/* pages/profile/profile.wxss */
.profile-page {
  padding: 24rpx;
  padding-bottom: 120rpx;
  min-height: 100vh;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.user-card__avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--accent) 0%, #ff8555 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.user-card__avatar-text {
  font-size: 36rpx;
  font-weight: 600;
  color: white;
}

.user-card__info {
  flex: 1;
  min-width: 0;
}

.user-card__name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.user-card__id {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 统计行 */
.stats-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
}

.stat-card__value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--accent);
}

.stat-card__label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

/* 菜单列表 */
.menu-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 32rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
}

.menu-item__icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.menu-item__title {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.menu-item__arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
}

/* 底部 */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.footer__text {
  font-size: 22rpx;
  color: var(--text-tertiary);
}
