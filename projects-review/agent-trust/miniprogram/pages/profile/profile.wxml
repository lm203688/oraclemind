<!-- pages/profile/profile.wxml -->
<view class="profile-page">
  <!-- 用户信息 -->
  <view class="user-card card">
    <view class="user-card__avatar">
      <text class="user-card__avatar-text">{{userName[0] || 'U'}}</text>
    </view>
    <view class="user-card__info">
      <text class="user-card__name">{{userName || '未登录'}}</text>
      <text class="user-card__id">{{userId || '点击登录'}}</text>
    </view>
    <view class="user-card__badge" wx:if="{{isLoggedIn}}">
      <view class="badge badge--accent">开发者</view>
    </view>
  </view>

  <!-- 快捷统计 -->
  <view class="stats-row">
    <view class="stat-card card">
      <text class="stat-card__value">{{agentCount}}</text>
      <text class="stat-card__label">Agent</text>
    </view>
    <view class="stat-card card">
      <text class="stat-card__value">{{totalTx}}</text>
      <text class="stat-card__label">交易</text>
    </view>
    <view class="stat-card card">
      <text class="stat-card__value">{{avgScore}}</text>
      <text class="stat-card__label">平均分</text>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-list">
    <view class="menu-item card" wx:for="{{menuItems}}" wx:key="title" bindtap="onMenuTap" data-action="{{item.action}}">
      <text class="menu-item__icon">{{item.icon}}</text>
      <text class="menu-item__title">{{item.title}}</text>
      <text class="menu-item__arrow">›</text>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text class="footer__text">AgentTrust Protocol v0.1.0</text>
    <text class="footer__text">github.com/lm203688/agent-trust-protocol</text>
    <text class="footer__text" wx:if="{{isLoggedIn}}" bindtap="handleLogout" style="color: var(--danger); margin-top: 16rpx;">退出登录</text>
  </view>
</view>
