/* pages/index/index.wxss */
.landing {
  min-height: 100vh;
  padding: 48rpx 24rpx;
  padding-bottom: 64rpx;
}

/* 品牌区 */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  margin-bottom: 48rpx;
}

.hero__logo {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.hero__logo-icon {
  font-size: 56rpx;
}

.hero__logo-text {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--accent);
  letter-spacing: 2rpx;
}

.hero__tagline {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.hero__subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 特色卡片 */
.features {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.feature-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 28rpx 24rpx;
}

.feature-card__icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.feature-card__title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.feature-card__desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 预览卡片 */
.preview {
  margin-bottom: 32rpx;
}

.preview__title {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
}

.preview__score {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.preview__score-value {
  font-size: 80rpx;
  font-weight: 700;
  color: var(--accent);
  line-height: 1;
}

.preview__score-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

.preview__dimensions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.preview__dim {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.preview__dim-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  width: 120rpx;
  flex-shrink: 0;
}

.preview__dim-bar {
  flex: 1;
  height: 8rpx;
  background-color: var(--bg-secondary);
  border-radius: 4rpx;
  overflow: hidden;
}

.preview__dim-fill {
  height: 100%;
  background-color: var(--accent);
  border-radius: 4rpx;
}

/* CTA 区 */
.cta {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.btn--lg {
  width: 100%;
  height: 96rpx;
  font-size: 32rpx;
}

.cta__hint {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 16rpx;
}

/* 底部 */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.footer__text {
  font-size: 22rpx;
  color: var(--text-tertiary);
}
