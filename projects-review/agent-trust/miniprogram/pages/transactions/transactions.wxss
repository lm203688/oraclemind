/* pages/transactions/transactions.wxss */
.tx-page {
  padding: 24rpx;
  padding-bottom: 120rpx;
  min-height: 100vh;
}

.filter-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.filter-item {
  padding: 8rpx 24rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  background-color: var(--bg-card);
}

.filter-item--active {
  background-color: rgba(255, 107, 53, 0.15);
  color: var(--accent);
}

.tx-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tx-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
}

.tx-item__left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tx-item__icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.tx-icon--success {
  background-color: rgba(16, 185, 129, 0.15);
  color: var(--success);
}

.tx-icon--fail {
  background-color: rgba(239, 68, 68, 0.15);
  color: var(--danger);
}

.tx-item__info {
  display: flex;
  flex-direction: column;
}

.tx-item__peer {
  font-size: 26rpx;
  color: var(--text-primary);
}

.tx-item__time {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.tx-item__right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.tx-item__amount {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.tx-item__protocol {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 0;
}

.empty-state__icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-state__text {
  font-size: 26rpx;
  color: var(--text-secondary);
}
