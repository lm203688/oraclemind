/* pages/dashboard/dashboard.wxss */
.dashboard {
  padding: 24rpx;
  padding-bottom: 120rpx; /* 给 tabbar 留空间 */
  min-height: 100vh;
}

/* 欢迎区 */
.welcome {
  margin-bottom: 32rpx;
}

.welcome__greeting {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.welcome__name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* 信任分卡片 */
.score-card {
  background: linear-gradient(135deg, #1a1a1a 0%, #141414 100%);
  border: 1rpx solid rgba(255, 107, 53, 0.2);
  padding: 32rpx;
}

.score-card__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.score-card__title {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.score-card__footer {
  display: flex;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--bg-secondary);
}

.score-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.score-meta__label {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.score-meta__value {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.text--success { color: var(--success); }
.text--danger { color: var(--danger); }

/* 维度列表 */
.dimensions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.dimension-item__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.dimension-item__name {
  font-size: 26rpx;
  color: var(--text-primary);
}

.dimension-item__score {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--accent);
}

.dimension-item__bar {
  width: 100%;
  height: 6rpx;
  background-color: var(--bg-secondary);
  border-radius: 3rpx;
  overflow: hidden;
}

.dimension-item__bar-fill {
  height: 100%;
  border-radius: 3rpx;
  transition: width 0.8s ease;
}

.dimension-item__desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

/* 分区头部（带查看全部链接） */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-link {
  font-size: 24rpx;
  color: var(--accent);
}

/* 交易列表 */
.tx-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tx-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
}

.tx-item__left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tx-item__icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.tx-icon--success {
  background-color: rgba(16, 185, 129, 0.15);
  color: var(--success);
}

.tx-icon--fail {
  background-color: rgba(239, 68, 68, 0.15);
  color: var(--danger);
}

.tx-item__info {
  display: flex;
  flex-direction: column;
}

.tx-item__peer {
  font-size: 26rpx;
  color: var(--text-primary);
}

.tx-item__time {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.tx-item__right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.tx-item__amount {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.tx-item__protocol {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.empty-state__icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-state__text {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.empty-state__hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* AI 洞察卡片 */
.insight-card {
  background: linear-gradient(135deg, rgba(255, 107, 53, 0.08) 0%, var(--bg-card) 100%);
  border-left: 4rpx solid var(--accent);
}

.insight-card__text {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.8;
}

.insight-card__footer {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--bg-secondary);
}

.insight-card__source {
  font-size: 22rpx;
  color: var(--accent);
}

.insight-card__time {
  font-size: 22rpx;
  color: var(--text-tertiary);
}
