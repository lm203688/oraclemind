</div>
</div>

<div class="footer">
<div class="container">
蜂群科研 v0.2.0 — AI生态缔造者 🌐<br>
RDKit真实计算 × 引用验证 × 蜂群协作 × 虚拟实验室
</div>
</div>

<!-- PWA安装提示横幅 -->
<div id="pwa-install-banner">
<div class="banner-icon">🐝</div>
<div class="banner-text">
<strong>添加到主屏幕</strong><br>
离线使用蜂群科研，体验更流畅
</div>
<button class="banner-btn" id="pwa-install-btn">安装</button>
<button class="banner-close" id="pwa-install-close">✕</button>
</div>

<script>
// ========== Service Worker 注册 ==========
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('/static/sw.js')
      .then((reg) => {
        console.log('✅ SW注册成功', reg.scope);
      })
      .catch((err) => {
        console.log('SW注册失败', err);
      });
  });
}

// ========== PWA安装提示 (beforeinstallprompt) ==========
let deferredPrompt = null;

window.addEventListener('beforeinstallprompt', (e) => {
  // 阻止默认弹窗
  e.preventDefault();
  deferredPrompt = e;
  // 显示自定义安装提示
  const banner = document.getElementById('pwa-install-banner');
  if (banner) {
    banner.classList.add('show');
  }
});

document.getElementById('pwa-install-btn')?.addEventListener('click', async () => {
  if (!deferredPrompt) return;
  deferredPrompt.prompt();
  const { outcome } = await deferredPrompt.userChoice;
  console.log('用户选择:', outcome);
  deferredPrompt = null;
  document.getElementById('pwa-install-banner').classList.remove('show');
  document.getElementById('pwa-install-banner').classList.add('hidden');
});

document.getElementById('pwa-install-close')?.addEventListener('click', () => {
  document.getElementById('pwa-install-banner').classList.remove('show');
  document.getElementById('pwa-install-banner').classList.add('hidden');
});

// 检测是否已安装
window.addEventListener('appinstalled', () => {
  console.log('✅ PWA已安装');
  const banner = document.getElementById('pwa-install-banner');
  if (banner) banner.style.display = 'none';
});

// 检测是否在standalone模式运行
if (window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone) {
  console.log('📱 PWA standalone模式');
  document.getElementById('pwa-install-banner')?.style.display = 'none';
}

const API = window.location.origin;
let currentResearchId = null;
let progressTimer = null;

// ========== Tab切换 ==========
function switchTab(tab, el) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  if (el) el.classList.add('active');
  ['start','run','progress','credits'].forEach(t => {
    const el2 = document.getElementById('tab-'+t);
    if (el2) el2.style.display = t === tab ? '' : 'none';
  });
}

function updateGuidance(text) {
  const hint = document.getElementById('next-step-hint');
  if (hint) hint.innerHTML = `<strong>👉 当前步骤：</strong>${text}`;
}

function showResult(title, content) {
  document.getElementById('result-section').style.display = '';
  const box = document.getElementById('result-box');
  box.innerHTML = `<h4>${title}</h4><pre>${content}</pre>`;
  box.scrollIntoView({behavior:'smooth'});
}

async function apiCall(method, path, data) {
  const opts = {method, headers: {'Content-Type':'application/json'}};
  if (data) opts.body = JSON.stringify(data);
  const r = await fetch(API + path, opts);
  return r.json();
}

// ========== 蜂任务选择 ==========
function onBeeChange() {
  const bee = document.getElementById('bee_type').value;
  const chemBox = document.getElementById('chem_options');
  const modeDiv = document.getElementById('pipeline_mode_div');
  const preciseBox = document.getElementById('precise_options');
  if (bee.startsWith('chemistry_bee')) {
    chemBox.style.display = '';
    modeDiv.style.display = 'none';
    if (preciseBox) preciseBox.style.display = 'none';
  } else if (bee === 'literature_bee_precise') {
    chemBox.style.display = 'none';
    modeDiv.style.display = 'none';
    if (preciseBox) preciseBox.style.display = '';
  } else {
    chemBox.style.display = 'none';
    modeDiv.style.display = bee === 'full_pipeline' ? '' : 'none';
    if (preciseBox) preciseBox.style.display = 'none';
  }
}

// ========== 积分 ==========
async function registerUser() {
  const uid = document.getElementById('credits_user_id').value;
  const r = await apiCall('POST', '/api/v1/swarm/register', {user_id: uid, email: uid+'@test.com'});
  showResult('注册结果', JSON.stringify(r, null, 2));
}

async function checkBalance() {
  const uid = document.getElementById('credits_user_id').value;
  const r = await apiCall('GET', `/api/v1/swarm/credits/balance?user_id=${uid}`);
  document.getElementById('credits_result').style.display = '';
  document.getElementById('credits_result').innerHTML = `<h4>积分余额</h4><pre>${JSON.stringify(r, null, 2)}</pre>`;
}

async function purchaseCredits() {
  const uid = document.getElementById('credits_user_id').value;
  const pack = document.getElementById('pack').value;
  const r = await apiCall('POST', '/api/v1/swarm/credits/purchase', {user_id: uid, pack});
  showResult('购买结果', JSON.stringify(r, null, 2));
}

// ========== 知识库 ==========
async function kbSearch() {
  const q = document.getElementById('kb_search_q').value;
  const r = await apiCall('GET', `/api/v1/swarm/kb/search?q=${encodeURIComponent(q)}`);
  const box = document.getElementById('kb_result');
  if (r.results && r.results.length > 0) {
    let html = `<p>找到 ${r.count} 条结果（引用价${r.cite_cost}积分，自跑验证${r.self_verify_cost}积分）</p>`;
    r.results.forEach(item => {
      html += `<div style="border:1px solid var(--border);padding:12px;margin:8px 0;border-radius:8px">
        <div style="font-weight:bold">${item.trust_label} ${item.claim}</div>
        <div style="color:var(--dim);font-size:13px;margin-top:4px">
          类型:${item.claim_type} | SMILES:${item.smiles||'无'} | 引用:${item.citations}次 | 实际值:${item.actual_value||'无'}
        </div>
        <div style="margin-top:6px">
          <button class="btn btn-outline" style="font-size:13px;padding:4px 12px" onclick="kbCite('${item.id}')">📋 引用(-800积分)</button>
          <button class="btn btn-outline" style="font-size:13px;padding:4px 12px" onclick="kbCrossDomain('${item.id}')">🧭 AI跨领域发现(-300积分)</button>
        </div>
      </div>`;
    });
    box.innerHTML = html;
  } else {
    box.innerHTML = '<p>未找到匹配结果</p>';
  }
  box.style.display = '';
}

async function kbCite(kbId) {
  const uid = document.getElementById('kb_user_id').value;
  const r = await apiCall('POST', `/api/v1/swarm/kb/${kbId}/cite`, {user_id: uid, research_id: 'manual'});
  if (r.success) {
    alert(`✅ 引用成功！消耗${r.cite_cost}积分，原作者获得${r.author_reward}积分\n你的余额: ${r.balance}`);
  } else {
    alert(`❌ ${r.error}`);
  }
}

async function kbCrossDomain(kbId) {
  const uid = document.getElementById('kb_user_id').value;
  const box = document.getElementById('kb_result');
  box.innerHTML = '<span class="loading"></span> AI分析中...（约30秒）';
  box.style.display = '';
  const r = await apiCall('POST', `/api/v1/swarm/kb/${kbId}/cross-domain`, {user_id: uid});
  if (r.success) {
    box.innerHTML = `<div style="border:1px solid var(--accent);padding:16px;border-radius:8px">
      <h3>🧭 跨领域发现报告</h3>
      <p style="color:var(--dim)">分析对象: ${r.claim}</p>
      <p style="color:var(--dim)">消耗: ${r.cost}积分 | 余额: ${r.balance}</p>
      <pre style="white-space:pre-wrap;margin-top:12px;font-size:14px;line-height:1.6">${r.analysis}</pre>
    </div>`;
  } else {
    box.innerHTML = `<p>❌ ${r.error}</p>`;
  }
}

async function kbUserItems() {
  const uid = document.getElementById('kb_user_id').value;
  const r = await apiCall('GET', `/api/v1/swarm/kb/user/${uid}`);
  const box = document.getElementById('kb_result');
  if (r.total > 0) {
    let html = `<p>你入库了 ${r.total} 条，累计被引用 ${r.total_citations} 次</p>`;
    r.items.forEach(item => {
      html += `<div style="border:1px solid var(--border);padding:12px;margin:8px 0;border-radius:8px">
        <div style="font-weight:bold">${item.trust_label} ${item.claim}</div>
        <div style="color:var(--dim);font-size:13px;margin-top:4px">
          引用:${item.citations}次 | 入库:${item.created} | 收益:${item.citations * 300}积分
        </div>
      </div>`;
    });
    box.innerHTML = html;
  } else {
    box.innerHTML = '<p>你还没有入库任何验证结果。运行验证蜂后可入库获得积分。</p>';
  }
  box.style.display = '';
}

async function kbStats() {
  const r = await apiCall('GET', '/api/v1/swarm/kb/stats');
  const box = document.getElementById('kb_result');
  box.innerHTML = `<div style="border:1px solid var(--border);padding:16px;border-radius:8px">
    <h3>📊 知识库统计</h3>
    <p>总条目: ${r.total_items}</p>
    <p>总引用: ${r.total_citations}</p>
    <p>按类型: ${JSON.stringify(r.by_type)}</p>
    <p>按信任: ${JSON.stringify(r.by_trust)}</p>
    <p>Top贡献者: ${r.top_contributors.map(c => `${c.user_id}(${c.deposits}条/${c.citations}引)`).join(', ')}</p>
  </div>`;
  box.style.display = '';
}

// ========== 启动研究 ==========
async function startResearch() {
  const btn = document.getElementById('startBtn');
  btn.innerHTML = '<span class="loading"></span> 启动中...';
  btn.disabled = true;

  const uid = document.getElementById('user_id').value;
  const topic = document.getElementById('topic').value;
  const desc = document.getElementById('description').value;

  if (!topic) { alert('请输入研究主题'); btn.innerHTML='🚀 启动研究项目'; btn.disabled=false; return; }

  try {
    const r = await apiCall('POST', '/api/v1/swarm/research/start', {user_id: uid, topic, description: desc});

    if (r.research_id) {
      currentResearchId = r.research_id;
      document.getElementById('research_id').value = r.research_id;
      document.getElementById('rid-hint').style.display = '';
      showResult('✅ 研究项目已启动', `研究ID: ${r.research_id}\n状态: ${r.status}\n\n👉 已自动跳转到"执行蜂群"标签页\n选择一个蜂任务并点击"执行任务"按钮`);

      // 自动跳到执行蜂群tab
      setTimeout(() => {
        const tabs = document.querySelectorAll('.tab');
        switchTab('run', tabs[1]);
        updateGuidance('研究项目已创建！选择一个蜂任务（推荐先试"文献蜂"或"化学蜂·性质预测"），然后点击"执行任务"');
        document.getElementById('playground').scrollIntoView({behavior:'smooth'});
      }, 1500);
    } else {
      showResult('启动失败', JSON.stringify(r, null, 2));
    }
  } catch(e) {
    showResult('错误', e.message);
  }

  btn.innerHTML = '🚀 启动研究项目';
  btn.disabled = false;
}

// ========== 执行蜂任务 ==========
async function runBee() {
  const btn = document.getElementById('runBtn');
  btn.innerHTML = '<span class="loading"></span> 执行中...';
  btn.disabled = true;

  const uid = document.getElementById('run_user_id').value;
  const rid = document.getElementById('research_id').value;
  let bee = document.getElementById('bee_type').value;

  if (!rid) {
    alert('请先在"① 启动研究"标签页创建研究项目');
    btn.innerHTML = '▶️ 执行任务';
    btn.disabled = false;
    return;
  }

  // 解析化学蜂子模式
  let chemMode = null;
  if (bee.startsWith('chemistry_bee_')) {
    chemMode = bee.split('_')[2]; // property/reaction/retro/quantum
    bee = 'chemistry_bee';
  }

  // 解析文献蜂深度调研模式
  let litMode = null;
  if (bee === 'literature_bee_deep') {
    litMode = 'deep';
    bee = 'literature_bee';
  } else if (bee === 'literature_bee_precise') {
    litMode = 'precise';
    bee = 'literature_bee';
  }

  const body = {user_id: uid, bee_type: bee};
  if (chemMode) body.chem_mode = chemMode;
  if (litMode) body.lit_mode = litMode;

  // 精读模式：传递论文输入
  if (litMode === 'precise') {
    const paperInput = document.getElementById('paper_input').value.trim();
    if (!paperInput) {
      alert('请输入论文DOI或标题');
      btn.innerHTML = '▶️ 执行任务';
      btn.disabled = false;
      return;
    }
    body.search_query = paperInput;
  }

  // 完整流程模式
  if (bee === 'full_pipeline') {
    body.mode = document.getElementById('pipeline_mode').value;
  }

  // 化学蜂参数
  if (bee === 'chemistry_bee') {
    body.smiles = document.getElementById('smiles').value || 'CCO';
  }

  // BYOK
  const byokUrl = document.getElementById('byok_url').value;
  if (byokUrl) {
    body.user_config = {
      byok_enabled: true,
      llm_url: byokUrl,
      llm_key: document.getElementById('byok_key').value,
      llm_model: document.getElementById('byok_model').value || 'glm-4',
    };
  }

  // 显示进度
  const taskName = document.getElementById('bee_type').selectedOptions[0].text;
  showProgress(taskName, rid);

  try {
    const r = await apiCall('POST', `/api/v1/swarm/research/${rid}/run`, body);

    let resultText = '';
    if (r.success || r.pending_gate) {
      resultText += `✅ 执行成功\n`;
      resultText += `引擎: ${r.engine || 'LLM'}\n`;
      resultText += `积分消耗: ${r.credits_spent || '?'} | 余额: ${r.balance || '?'}\n\n`;

      // Co-Pilot gate: 显示批准界面
      if (r.pending_gate) {
        resultText += `=== ⏸ 等待批准 ===\n`;
        resultText += `当前步骤: ${r.pending_gate.label}\n`;
        resultText += `提示: ${r.pending_gate.message}\n\n`;
        if (r.pending_gate.review_data) {
          if (r.pending_gate.review_data.papers) {
            resultText += `--- 文献综述结果 ---\n`;
            r.pending_gate.review_data.papers.forEach(p => {
              resultText += `  ${p.title} (${p.year||'?'})\n`;
            });
            resultText += '\n';
          }
          if (r.pending_gate.review_data.summary) {
            resultText += `--- 综述摘要 ---\n${r.pending_gate.review_data.summary}\n\n`;
          }
          if (r.pending_gate.review_data.hypotheses) {
            resultText += `--- 研究假设 ---\n`;
            r.pending_gate.review_data.hypotheses.forEach((h,i) => {
              resultText += `  ${i+1}. [${h.confidence}] ${h.content}\n`;
            });
            resultText += '\n';
          }
        }
        resultText += `👇 在下方选择"批准继续"或"终止流程"`;

        showResult(`⏸ 等待批准: ${r.pending_gate.label}`, resultText);
        showApprovalButtons(rid, uid, r.pending_gate.step);
        finishProgress(true);
        updateGuidance('任务暂停等待批准！查看结果后，在下方点击"批准继续"或"终止流程"');
        btn.innerHTML = '▶️ 执行任务';
        btn.disabled = false;
        return;
      }

      if (r.verified_count !== undefined) {
        resultText += `=== 引用验证 ===\n验证通过: ${r.verified_count}/${r.verified_count + r.unverified_count}篇\n`;
        resultText += `验证层: ${(r.verification_report && r.verification_report.layers) ? r.verification_report.layers.join(' → ') : 'Semantic Scholar'}\n`;
        if (r.verification_report && r.verification_report.search_rounds) {
          resultText += `检索轮次: ${r.verification_report.search_rounds}轮\n`;
        }
        resultText += '\n';
      }
      // 深度调研模式额外信息
      if (r.sub_questions) {
        resultText += `=== 深度调研拆解 ===\n`;
        resultText += `研究范围: ${r.research_scope || '未指定'}\n`;
        if (r.key_concepts && r.key_concepts.length) {
          resultText += `核心概念: ${r.key_concepts.join(', ')}\n`;
        }
        resultText += `子问题:\n`;
        r.sub_questions.forEach((sq, i) => {
          resultText += `  ${i+1}. ${sq.question}\n`;
          if (sq.keywords_en) resultText += `     🔍 ${sq.keywords_en}\n`;
        });
        resultText += '\n';
      }
      // 精读模式额外信息
      if (r.mode === 'precise') {
        const pi = r.paper_info || {};
        resultText += `=== 论文信息 ===\n`;
        resultText += `标题: ${pi.title || ''}\n`;
        resultText += `作者: ${pi.authors || ''}\n`;
        resultText += `年份: ${pi.year || '?'} | 期刊: ${pi.journal || '?'}\n`;
        resultText += `DOI: ${pi.doi || '无'} | 引用数: ${pi.citation_count || 0}\n`;
        if (pi.match_score) resultText += `匹配度: ${(pi.match_score*100).toFixed(0)}%\n`;
        resultText += `\n=== 一句话速读 ===\n${r.quick_read || ''}\n\n`;
        if (r.key_findings && r.key_findings.length) {
          resultText += `=== 关键发现 ===\n`;
          r.key_findings.forEach((f,i) => resultText += `${i+1}. ${f}\n`);
          resultText += '\n';
        }
        if (r.methodology && r.methodology.approach) {
          resultText += `=== 方法拆解 ===\n`;
          resultText += `路线: ${r.methodology.approach}\n`;
          resultText += `细节: ${r.methodology.details || ''}\n`;
          if (r.methodology.datasets) resultText += `数据集: ${r.methodology.datasets}\n`;
          if (r.methodology.tools) resultText += `工具: ${r.methodology.tools}\n`;
          resultText += '\n';
        }
        if (r.limitations && r.limitations.length) {
          resultText += `=== 局限性 ===\n`;
          r.limitations.forEach((l,i) => resultText += `${i+1}. ${l}\n`);
          resultText += '\n';
        }
        if (r.verifiable_claims && r.verifiable_claims.length) {
          resultText += `=== ✅ 可验证声明 (${r.verifiable_claims.length}条) ===\n`;
          resultText += `💡 下一步可选择"验证蜂"用RDKit真实计算验证\n`;
          r.verifiable_claims.forEach((c,i) => {
            resultText += `${i+1}. [${c.claim_type||'other'}] ${c.claim}\n`;
            if (c.smiles) resultText += `   SMILES: ${c.smiles}\n`;
            if (c.expected_value !== null && c.expected_value !== undefined) {
              resultText += `   预期值: ${c.expected_value} (${c.property_name||''})\n`;
            }
          });
          resultText += '\n';
        }
        if (r.research_questions && r.research_questions.length) {
          resultText += `=== 引发的研究问题 ===\n`;
          r.research_questions.forEach((q,i) => resultText += `${i+1}. ${q}\n`);
          resultText += '\n';
        }
      }
      if (r.summary) {
        const reportTitle = r.mode === 'deep' ? '深度调研报告' : (r.mode === 'precise' ? '精读报告' : '文献综述');
        resultText += `=== ${reportTitle} ===\n${r.summary}\n\n`;
      }
      if (r.hypotheses) {
        resultText += `=== 研究假设 ===\n`;
        r.hypotheses.forEach((h,i) => {
          resultText += `${i+1}. [置信度${h.confidence}] ${h.content}\n`;
          resultText += `   依据: ${h.basis}\n   验证: ${h.method}\n\n`;
        });
      }
      if (r.report) resultText += `=== 化学计算报告 ===\n${r.report}\n\n`;
      if (r.paper) resultText += `=== 论文草稿 (${r.word_count}字) ===\n${r.paper}\n\n`;
      if (r.analysis) resultText += `=== 分析报告 ===\n${r.analysis}\n\n`;
      if (r.review) resultText += `=== 评审报告 ===\n${r.review}\n\n`;
      if (r.quantum_analysis) resultText += `=== 量子化学分析 ===\n${r.quantum_analysis}\n\n`;
      if (r.papers) {
        resultText += `=== 检索论文 ===\n`;
        r.papers.forEach(p => {
          const verified = p.verified ? '✅' : '❌';
          resultText += `${verified} ${p.title} (${p.year||'?'}) DOI:${p.doi||'无'}\n`;
        });
        resultText += '\n';
      }
    } else {
      resultText = `❌ 失败: ${r.error || JSON.stringify(r, null, 2)}`;
    }

    showResult(`蜂群任务: ${taskName}`, resultText);
    finishProgress(r.success);
    updateGuidance('任务执行完成！可在上方查看结果，或选择其他蜂任务继续研究');
  } catch(e) {
    showResult('错误', e.message);
    finishProgress(false, e.message);
  }

  btn.innerHTML = '▶️ 执行任务';
  btn.disabled = false;
}

// ========== 进度展示 ==========
function showProgress(taskName, rid) {
  // 切到进度tab
  const tabs = document.querySelectorAll('.tab');
  switchTab('progress', tabs[2]);

  document.getElementById('progress-empty').style.display = 'none';
  document.getElementById('progress-content').style.display = '';
  document.getElementById('progress-task-name').textContent = taskName;
  document.getElementById('progress-status').textContent = '执行中...';
  document.getElementById('progress-fill').style.width = '30%';
  document.getElementById('progress-result').innerHTML = '';

  const steps = [
    {name: '提交任务', state: 'done'},
    {name: '蜂群调度', state: 'active'},
    {name: '执行中', state: 'pending'},
    {name: '完成', state: 'pending'},
  ];
  renderSteps(steps);

  // 模拟进度推进
  let pct = 30;
  if (progressTimer) clearInterval(progressTimer);
  progressTimer = setInterval(() => {
    pct = Math.min(pct + 10, 80);
    document.getElementById('progress-fill').style.width = pct + '%';
    if (pct >= 50) {
      steps[2].state = 'active';
      renderSteps(steps);
    }
  }, 2000);

  // 同时轮询真实状态
  pollStatus(rid);
}

function renderSteps(steps) {
  const ul = document.getElementById('step-list');
  ul.innerHTML = steps.map(s => {
    const icon = s.state === 'done' ? '✅' : s.state === 'active' ? '⏳' : '⬜';
    return `<li class="${s.state}"><span class="step-icon">${icon}</span> ${s.name}</li>`;
  }).join('');
}

function finishProgress(success, error) {
  if (progressTimer) { clearInterval(progressTimer); progressTimer = null; }
  document.getElementById('progress-fill').style.width = '100%';
  document.getElementById('progress-status').textContent = success ? '✅ 完成' : '❌ 失败';
  const steps = document.querySelectorAll('#step-list li');
  steps.forEach(s => { s.className = success ? 'done' : 'pending'; });
  if (steps.length >= 3) steps[2].querySelector('.step-icon').textContent = success ? '✅' : '❌';
  if (steps.length >= 4) steps[3].querySelector('.step-icon').textContent = success ? '✅' : '❌';
}

async function pollStatus(rid) {
  // 每3秒轮询一次研究状态
  let count = 0;
  const timer = setInterval(async () => {
    count++;
    if (count > 20) { clearInterval(timer); return; } // 最多60秒
    try {
      const r = await apiCall('GET', `/api/v1/swarm/research/${rid}/status`);
      if (r.status === 'completed' || r.status === 'failed') {
        clearInterval(timer);
      }
    } catch(e) {}
  }, 3000);
}

// ========== Co-Pilot: Gate批准 ==========
function showApprovalButtons(rid, uid, nextStep) {
  const box = document.getElementById('result-box');
  const approvalHtml = `
    <div style="margin-top:16px;padding:16px;background:rgba(108,92,231,.1);border:1px solid var(--accent);border-radius:12px">
      <h4 style="color:var(--accent);margin-bottom:12px">⏸ 等待你的决定</h4>
      <div style="margin-bottom:12px">
        <label style="font-size:14px;color:var(--dim)">反馈（可选，Co-Pilot模式会传给下一步蜂）:</label>
        <textarea class="input" id="gate_feedback" placeholder="如：假设方向不错，但第2个假设已有相关论文，请调整..." style="margin-top:4px;min-height:60px"></textarea>
      </div>
      <div style="display:flex;gap:12px">
        <button class="btn btn-primary" onclick="approveGate('${rid}','${uid}',true)" style="background:var(--green)">✅ 批准继续</button>
        <button class="btn btn-outline" onclick="approveGate('${rid}','${uid}',false)" style="border-color:var(--red);color:var(--red)">❌ 终止流程</button>
      </div>
    </div>
  `;
  // 追加到结果区
  box.innerHTML += approvalHtml;
  box.scrollIntoView({behavior:'smooth'});
}

async function approveGate(rid, uid, approved) {
  const feedback = document.getElementById('gate_feedback')?.value || '';
  showResult('⏳ 处理中...', approved ? '正在继续执行...' : '正在终止流程...');

  try {
    const r = await apiCall('POST', `/api/v1/swarm/research/${rid}/approve`, {
      user_id: uid,
      approved: approved,
      feedback: feedback,
    });

    let resultText = '';
    if (r.status === 'cancelled') {
      resultText = '❌ 流程已终止';
      showResult('流程终止', resultText);
      updateGuidance('流程已终止。可在"① 启动研究"重新开始');
      return;
    }

    if (r.success !== false) {
      resultText += `✅ ${approved ? '已批准' : '已处理'}\n`;
      if (r.steps) {
        resultText += `\n=== 执行步骤 ===\n`;
        r.steps.forEach(s => {
          resultText += `${s.success ? '✅' : '❌'} ${s.bee}`;
          if (s.word_count) resultText += ` (${s.word_count}字)`;
          if (s.error) resultText += ` — ${s.error}`;
          resultText += '\n';
        });
      }
      if (r.paper) {
        resultText += `\n=== 论文草稿 ===\n${r.paper}\n`;
      }
      if (r.pending_gate) {
        resultText += `\n=== ⏸ 下一个Gate: ${r.pending_gate.label} ===\n`;
        resultText += `${r.pending_gate.message}\n\n`;
        if (r.pending_gate.review_data?.hypotheses) {
          resultText += `--- 研究假设 ---\n`;
          r.pending_gate.review_data.hypotheses.forEach((h,i) => {
            resultText += `  ${i+1}. [${h.confidence}] ${h.content}\n`;
          });
          resultText += '\n👇 在下方选择"批准继续"或"终止流程"';
        }
        showResult(`⏸ 等待批准: ${r.pending_gate.label}`, resultText);
        showApprovalButtons(rid, uid, r.pending_gate.step);
        updateGuidance('下一步暂停等待批准！查看结果后继续');
        return;
      }
      if (r.status === 'completed') {
        resultText += `\n🎉 全流程完成！`;
        showResult('✅ 全流程完成', resultText);
        updateGuidance('全流程完成！可在结果区查看论文，或开始新的研究');
      } else {
        showResult('执行结果', resultText);
      }
    } else {
      showResult('❌ 失败', r.error || JSON.stringify(r, null, 2));
    }
  } catch(e) {
    showResult('错误', e.message);
  }
}
</script>
</body>
</html>
