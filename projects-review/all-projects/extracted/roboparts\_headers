# Vercel headers
/stl/*
  Cache-Control: public, max-age=31536000, immutable
  Content-Disposition: attachment
  X-Content-Type-Options: nosniff

/css/*
  Cache-Control: public, max-age=86400
  X-Content-Type-Options: nosniff

/js/*
  Cache-Control: public, max-age=86400
  X-Content-Type-Options: nosniff

/*.js
  Cache-Control: public, max-age=86400
  X-Content-Type-Options: nosniff

/data/*
  Cache-Control: public, max-age=3600
  X-Content-Type-Options: nosniff

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://fonts.googleapis.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://*.supabase.co https://*.supabase.in; connect-src 'self' https://*.supabase.co https://*.supabase.in https://api.xunhupay.com; frame-ancestors 'none'
