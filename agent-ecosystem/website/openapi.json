{
  "openapi": "3.0.0",
  "info": {
    "title": "Agent Ecosystem API",
    "version": "1.0.0",
    "description": "AI Agent ecosystem with 594 entities"
  },
  "servers": [
    {
      "url": "https://agent.genetech.tools/api"
    }
  ],
  "paths": {
    "/entities.json": {
      "get": {
        "summary": "Get all entities",
        "responses": {
          "200": {
            "description": "Entity list"
          }
        }
      }
    },
    "/entities/{id}": {
      "get": {
        "summary": "Get entity by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Entity detail"
          }
        }
      }
    },
    "/search": {
      "get": {
        "summary": "Search entities",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results"
          }
        }
      }
    }
  }
}