#!/bin/bash
# ATEX v6.0 环境变量配置
# 复制此文件为 env.sh.local 并填入真实值

# ── 必填 ──
export DEEPSEEK_API_KEY=""          # DeepSeek API Key（从 https://platform.deepseek.com 获取）

# ── 支付（二选一，至少配一个） ──
export XUNHUPAY_APP_ID=""           # 虎皮椒 App ID
export XUNHUPAY_APP_SECRET=""       # 虎皮椒 App Secret
export NOWPAYMENTS_API_KEY=""       # NOWPayments API Key（Crypto支付）

# ── 可选 ──
export ATEX_PORT=8420               # 服务端口
export ATEX_ADMIN_KEY=""            # 管理员密钥（用于/admin接口）
